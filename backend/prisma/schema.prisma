generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  RESELLER
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
  PENDING
}

enum LicenseType {
  PERMANENT
  TIME_LIMITED
  TRIAL
}

enum TransactionType {
  TOPUP
  DEDUCT
  TRANSFER_IN
  TRANSFER_OUT
  LICENSE_PURCHASE
  REFUND
}

enum LogAction {
  LOGIN
  LOGOUT
  REGISTER
  LICENSE_CREATE
  LICENSE_UPDATE
  LICENSE_DELETE
  LICENSE_SUSPEND
  LICENSE_RESUME
  LICENSE_EXPIRE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  SETTINGS_UPDATE
  API_ACCESS
  FAILED_LOGIN
  TOKEN_REFRESH
  BALANCE_TOPUP
  BALANCE_DEDUCT
  TRANSFER
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  password     String
  role         Role     @default(USER)
  balance      Float    @default(0)
  isActive     Boolean  @default(true)
  avatar       String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  licenses      License[]
  transactions  Transaction[]
  logs          Log[]
  refreshTokens RefreshToken[]
  sessions      Session[]
  sentTransfers     Transaction[] @relation("SentTransfers")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isActive])
}

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Float    @default(0)
  isActive    Boolean  @default(true)
  version     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  licenses License[]

  @@index([isActive])
}

model License {
  id           String        @id @default(cuid())
  key          String        @unique
  userId       String?
  productId    String
  status       LicenseStatus @default(ACTIVE)
  type         LicenseType   @default(TIME_LIMITED)
  expiresAt    DateTime?
  maxDevices   Int           @default(1)
  note         String?
  data         Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product  @relation(fields: [productId], references: [id])
  devices  LicenseDevice[]

  @@index([key])
  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([type])
  @@index([expiresAt])
}

model LicenseDevice {
  id         String   @id @default(cuid())
  licenseId  String
  deviceId   String
  deviceName String?
  ip         String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  license License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, deviceId])
  @@index([licenseId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  senderId    String?
  type        TransactionType
  amount      Float
  balanceBefore Float
  balanceAfter  Float
  description String?
  reference   String?         @unique
  createdAt   DateTime        @default(now())

  user   User  @relation(fields: [userId], references: [id])
  sender User? @relation("SentTransfers", fields: [senderId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Log {
  id        String    @id @default(cuid())
  userId    String?
  action    LogAction
  ip        String?
  userAgent String?
  details   Json?
  success   Boolean   @default(true)
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([success])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  ip        String?
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  updatedAt DateTime @updatedAt

  @@index([group])
}
